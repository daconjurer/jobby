# Build stage
FROM golang:1.25 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /jobs-dispatcher ./cmd/jobs-dispatcher

# Runtime stage
FROM alpine:3.21
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /jobs-dispatcher /app/jobs-dispatcher
ENTRYPOINT ["/app/jobs-dispatcher"]
