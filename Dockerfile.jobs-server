# Build stage
FROM golang:1.25 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /jobs-server ./cmd/jobs-server

# Runtime stage
FROM alpine:3.21
RUN apk --no-cache add ca-certificates wget
WORKDIR /app
COPY --from=builder /jobs-server /app/jobs-server
COPY config/job-topics.yaml /app/config/job-topics.yaml
ENV GIN_MODE=release
EXPOSE 3001
ENTRYPOINT ["/app/jobs-server"]
