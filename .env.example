# Jobs HTTP API (cmd/jobs-server)
APP_PORT=3001

# MongoDB Configuration (Single Database: jobby)
# Host binary / integration tests — Mongo published on localhost:27018 (replica set rs0)
MONGODB_URI=mongodb://jobby_app:jobby_app_pass@localhost:27018/jobby?authSource=jobby&replicaSet=rs0
# In-cluster (Compose) — hostname mongodb, port 27017; set in compose.yml, not needed on host
# MONGODB_URI=mongodb://jobby_app:jobby_app_pass@mongodb:27017/jobby?authSource=jobby&replicaSet=rs0
MONGODB_DATABASE=jobby
MONGODB_TIMEOUT=10s

# Collection Names (within jobby database)
MONGODB_COLLECTION_METADATA=job_metadata
MONGODB_COLLECTION_LOGS=job_logs

# Connection Pool Settings (Optional)
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10

# Job name → topic YAML manifest (jobs-server enqueue; default: config/job-topics.yaml)
JOB_TOPICS_CONFIG_PATH=config/job-topics.yaml

# Dispatch worker (cmd/jobs-dispatcher) — change stream + poll → Pulsar
PULSAR_SERVICE_URL=pulsar://localhost:6650
# Subscription name reserved for executor consumers (default: jobber)
PULSAR_SUBSCRIPTION_NAME=jobber
DISPATCH_POLL_INTERVAL=5s
DISPATCH_POLL_BATCH_SIZE=50
DISPATCH_MAX_ATTEMPTS=5
DISPATCH_STREAM_MAX_POOL_SIZE=2
# Optional; empty disables MongoDB change stream resume token persistence
DISPATCH_STREAM_MONGODB_RESUME_TOKEN_PATH=

# Docker Compose — migrate service (admin; mapped to MONGO_URI in compose.yml)
COMPOSE_MONGODB_URI=mongodb://jobby_admin:jobby_admin_pass@mongodb:27017/jobby?authSource=admin&replicaSet=rs0
